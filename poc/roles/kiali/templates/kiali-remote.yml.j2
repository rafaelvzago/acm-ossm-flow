apiVersion: kiali.io/v1alpha1
kind: Kiali
metadata:
  name: kiali
  namespace: {{ kiali_cr_ns }}
spec:
  auth:
    openshift:
      redirect_uris:
      - "https://{{ kiali_host }}/api/auth/callback/{{ clusters.spoke_two.name }}"
  deployment:
    namespace: {{ kiali_ns }}
    remote_cluster_resources_only: true
