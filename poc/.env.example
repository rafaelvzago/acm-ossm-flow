# OSSM Multi-Cluster POC - Required Environment Variables
#
# Login to each cluster and point these at the resulting kubeconfig files:
#
#   KUBECONFIG=~/.kube/west oc login --server=https://api.west.example.com:6443 --token=sha256~xxx
#   KUBECONFIG=~/.kube/east oc login --server=https://api.east.example.com:6443 --token=sha256~yyy
#
KUBECONFIG_WEST=~/.kube/west
KUBECONFIG_EAST=~/.kube/east
