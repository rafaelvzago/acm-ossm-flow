# Copie para .env e ajuste. NÃO commite .env nem kubeconfigs.
#
# Faça login em cada cluster ANTES de rodar o Ansible (placeholders):
#
#   KUBECONFIG=~/.kube/hub oc login --server=https://api.hub.example.com:6443 \
#     -u=kubeadmin -p='<SENHA>' --insecure-skip-tls-verify
#   KUBECONFIG=~/.kube/spoke oc login --server=https://api.spoke.example.com:6443 \
#     -u=kubeadmin -p='<SENHA>' --insecure-skip-tls-verify
#   KUBECONFIG=~/.kube/spoke-two oc login --server=https://api.spoke-two.example.com:6443 \
#     -u=kubeadmin -p='<SENHA>' --insecure-skip-tls-verify
#
# Depois exporte os caminhos (não as senhas):

KUBECONFIG_HUB=~/.kube/hub
KUBECONFIG_SPOKE=~/.kube/spoke
KUBECONFIG_SPOKE_TWO=~/.kube/spoke-two

# Opcional: PATH com istioctl 1.30.1
# PATH=$HOME/.local/bin:$PATH
